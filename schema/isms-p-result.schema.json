{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/hhyem/ISMS-P-Compliance-Gate/schema/isms-p-result.schema.json",
  "title": "ISMS-P Compliance Result",
  "type": "object",
  "required": [
    "schema_version", "run_id", "control_id", "control_name",
    "category", "status", "tool", "owner", "timestamp", "evidence_path"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id": { "type": "string" },
    "control_id": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "control_name": { "type": "string" },
    # 3가지 등급을 강제하는 필드
    "category": { "type": "string", "enum": ["auto", "semi-auto", "checklist"] },
    "status": { "type": "string", "enum": ["PASS", "FAIL", "NOT_APPLICABLE", "MANUAL_REQUIRED", "ERROR"] },
    "tool": { "type": "string" },
    "owner": { "type": "string", "enum": ["민지", "서윤", "예원", "혜민", "정은"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "pr_number": { "type": ["integer", "null"] },
    "commit_sha": { "type": ["string", "null"] },
    "scope": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["message", "severity"],
        "properties": {
          "file": { "type": ["string", "null"] },
          "line": { "type": ["integer", "null"] },
          "message": { "type": "string" },
          "severity": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW", "INFO"] }
        }
      }
    },
    "checklist_items": { "type": "array", "items": { "type": "string" } },
    "evidence_path": { "type": "string" }
  },
  "allOf": [
    { "if": { "properties": { "category": { "const": "semi-auto" } } }, "then": { "required": ["scope"] } },
    { "if": { "properties": { "category": { "const": "checklist" } } }, "then": { "required": ["checklist_items"] } }
  ]
}
